# Root Docker Compose environment example.
# Copy to .env.prod on the server or for a local production-like run.

# Database
POSTGRES_DB=aml_db
POSTGRES_USER=aml_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aml_user:change_me@postgres:5432/aml_db?schema=aml_task

# API
PORT=3000
BACKEND_PORT=3000
NODE_ENV=production

# JWT auth
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Infrastructure
REDIS_HOST=redis
REDIS_PORT=6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
LOG_LEVEL=info

# Docker Hub image used by docker-compose.prod.yaml
DOCKERHUB_BACKEND_REPO=your_dockerhub_username/aml-task-backend
BACKEND_IMAGE_TAG=latest
