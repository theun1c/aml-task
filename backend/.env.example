# REMOTE DB MODE
# APP
NODE_ENV=development
PORT=3000

# DATABASE ACCESS
# Use an SSH tunnel and point DATABASE_URL to the local tunnel port.
# Example tunnel:
# ssh -L 5433:127.0.0.1:5432 user@your-server
POSTGRES_DB=aml_db
POSTGRES_USER=aml_user
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433
DATABASE_URL=postgresql://aml_user:change-me@localhost:5433/aml_db?schema=aml_task

# JWT AUTH
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
