generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  previewFeatures        = ["partialIndexes"]
  generatedFileExtension = "ts"
  importFileExtension    = "js"
  moduleFormat           = "cjs"
  runtime                = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model users {
  id                               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                            String                 @unique @db.Citext
  password_hash                    String
  full_name                        String                 @db.VarChar(200)
  avatar_url                       String?
  settings                         Json                   @default("{}")
  is_active                        Boolean                @default(true)
  last_login_at                    DateTime?              @db.Timestamptz(6)
  row_version                      BigInt                 @default(1)
  created_at                       DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime               @default(now()) @db.Timestamptz(6)
  deleted_at                       DateTime?              @db.Timestamptz(6)
  first_name                       String?                @db.VarChar(100)
  last_name                        String?                @db.VarChar(100)
  activity_log                     activity_log[]
  attachments                      attachments[]
  audit_log                        audit_log[]
  comments                         comments[]
  issue_relations                  issue_relations[]
  issue_status_history             issue_status_history[]
  issue_watchers                   issue_watchers[]
  issues_issues_assignee_idTousers issues[]               @relation("issues_assignee_idTousers")
  issues_issues_reporter_idTousers issues[]               @relation("issues_reporter_idTousers")
  notifications                    notifications[]
  project_invitations              project_invitations[]
  project_members                  project_members[]
  projects                         projects[]
  time_logs                        time_logs[]
  user_sessions                    user_sessions[]

  @@index([deleted_at], map: "ix_users_deleted_at")
  @@index([is_active], map: "ix_users_is_active", where: raw("(deleted_at IS NULL)"))
}

