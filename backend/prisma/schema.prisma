generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  previewFeatures        = ["partialIndexes"]
  generatedFileExtension = "ts"
  moduleFormat           = "cjs"
  runtime                = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model users {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String            @unique @db.Citext
  password_hash   String
  name            String            @db.VarChar(200)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  project_members project_members[]
  projects        projects[]
  sessions        sessions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model issues {
  id                                                             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id                                                     String           @db.Uuid
  sprint_id                                                      String?          @db.Uuid
  status_id                                                      String           @db.Uuid
  creator_id                                                     String           @db.Uuid
  assignee_id                                                    String?          @db.Uuid
  title                                                          String           @db.VarChar(200)
  description                                                    String?
  type                                                           issue_type
  position                                                       Int              @default(0)
  created_at                                                     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                                                     DateTime         @default(now()) @db.Timestamptz(6)
  project_members_issues_project_id_assignee_idToproject_members project_members? @relation("issues_project_id_assignee_idToproject_members", fields: [project_id, assignee_id], references: [project_id, user_id], onUpdate: Restrict, map: "fk_issues_assignee_member")
  project_members_issues_project_id_creator_idToproject_members  project_members  @relation("issues_project_id_creator_idToproject_members", fields: [project_id, creator_id], references: [project_id, user_id], onUpdate: Restrict, map: "fk_issues_creator_member")
  projects                                                       projects         @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_issues_project")
  sprints                                                        sprints?         @relation(fields: [project_id, sprint_id], references: [project_id, id], onUpdate: Restrict, map: "fk_issues_sprint_same_project")
  statuses                                                       statuses         @relation(fields: [project_id, status_id], references: [project_id, id], onUpdate: Restrict, map: "fk_issues_status_same_project")

  @@index([assignee_id], map: "ix_issues_assignee_id")
  @@index([project_id], map: "ix_issues_project_id")
  @@index([project_id, sprint_id, position], map: "ix_issues_project_sprint_position")
  @@index([project_id, sprint_id, status_id, position], map: "ix_issues_project_sprint_status_position")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model project_members {
  id                                                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id                                            String       @db.Uuid
  user_id                                               String       @db.Uuid
  role                                                  project_role
  created_at                                            DateTime     @default(now()) @db.Timestamptz(6)
  issues_issues_project_id_assignee_idToproject_members issues[]     @relation("issues_project_id_assignee_idToproject_members")
  issues_issues_project_id_creator_idToproject_members  issues[]     @relation("issues_project_id_creator_idToproject_members")
  projects                                              projects     @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_project_members_project")
  users                                                 users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_project_members_user")

  @@unique([project_id, user_id], map: "uq_project_members_project_user")
  @@index([user_id], map: "ix_project_members_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model projects {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String            @db.VarChar(200)
  project_key     String            @unique @db.VarChar(20)
  description     String?
  owner_id        String            @db.Uuid
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  issues          issues[]
  project_members project_members[]
  users           users             @relation(fields: [owner_id], references: [id], onUpdate: Restrict, map: "fk_projects_owner")
  sprints         sprints?
  statuses        statuses?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sprints {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id String        @unique(map: "uq_sprints_one_active_per_project", where: raw("(status = 'active'::sprint_status)")) @db.Uuid
  name       String        @db.VarChar(150)
  status     sprint_status @default(planned)
  created_at DateTime      @default(now()) @db.Timestamptz(6)
  updated_at DateTime      @default(now()) @db.Timestamptz(6)
  issues     issues[]
  projects   projects      @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_sprints_project")

  @@unique([project_id, name], map: "uq_sprints_project_name")
  @@unique([project_id, id], map: "uq_sprints_project_id_id")
  @@index([project_id, status], map: "ix_sprints_project_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model statuses {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id String          @unique(map: "uq_statuses_one_default_per_project", where: raw("(is_default = true)")) @db.Uuid
  name       String          @db.VarChar(100)
  category   status_category
  position   Int
  is_default Boolean         @default(false)
  is_final   Boolean         @default(false)
  created_at DateTime        @default(now()) @db.Timestamptz(6)
  updated_at DateTime        @default(now()) @db.Timestamptz(6)
  issues     issues[]
  projects   projects        @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_statuses_project")

  @@unique([project_id, name], map: "uq_statuses_project_name")
  @@unique([project_id, position], map: "uq_statuses_project_position")
  @@unique([project_id, id], map: "uq_statuses_project_id_id")
  @@index([project_id, category], map: "ix_statuses_project_category")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sessions {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String    @db.Uuid
  refresh_token_hash String
  expires_at         DateTime  @db.Timestamptz(6)
  revoked_at         DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @db.Timestamptz(6)
  users              users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_sessions_user")

  @@index([expires_at], map: "ix_sessions_expires_at")
  @@index([revoked_at], map: "ix_sessions_revoked_at")
  @@index([user_id], map: "ix_sessions_user_id")
}

enum issue_type {
  task
  bug
}

enum project_role {
  owner
  member
}

enum sprint_status {
  planned
  active
  completed
}

enum status_category {
  todo
  in_progress
  done
}
