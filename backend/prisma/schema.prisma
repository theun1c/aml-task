  parent_issue_id                                         String?                @db.Uuid
  title                                                   String                 @db.VarChar(500)
  description                                             String?
  reporter_id                                             String                 @db.Uuid
  assignee_id                                             String?                @db.Uuid
  priority                                                String                 @default("medium") @db.VarChar(20)
  story_points                                            Decimal?               @db.Decimal(5, 2)
  due_date                                                DateTime?              @db.Date
  rank_position                                           Decimal?               @db.Decimal(20, 10)
  original_estimate_minutes                               Int?
  remaining_estimate_minutes                              Int?
  row_version                                             BigInt                 @default(1)
  created_at                                              DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                                              DateTime               @default(now()) @db.Timestamptz(6)
  deleted_at                                              DateTime?              @db.Timestamptz(6)
  attachments                                             attachments[]
  comments                                                comments[]
  issue_relations_issue_relations_source_issue_idToissues issue_relations[]      @relation("issue_relations_source_issue_idToissues")
  issue_relations_issue_relations_target_issue_idToissues issue_relations[]      @relation("issue_relations_target_issue_idToissues")
  issue_status_history                                    issue_status_history[]
  issue_watchers                                          issue_watchers[]
  users_issues_assignee_idTousers                         users?                 @relation("issues_assignee_idTousers", fields: [assignee_id], references: [id], onUpdate: Restrict, map: "fk_issues_assignee")
  issues                                                  issues?                @relation("issuesToissues", fields: [parent_issue_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_issues_parent")
  other_issues                                            issues[]               @relation("issuesToissues")
  projects                                                projects               @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_issues_project")
  users_issues_reporter_idTousers                         users                  @relation("issues_reporter_idTousers", fields: [reporter_id], references: [id], onUpdate: Restrict, map: "fk_issues_reporter")
  sprints                                                 sprints?               @relation(fields: [sprint_id], references: [id], onUpdate: Restrict, map: "fk_issues_sprint")
  statuses                                                statuses               @relation(fields: [status_id], references: [id], onUpdate: Restrict, map: "fk_issues_status")
  issue_types                                             issue_types            @relation(fields: [type_id], references: [id], onUpdate: Restrict, map: "fk_issues_type")
  time_logs                                               time_logs[]

  @@unique([project_id, issue_number], map: "uq_issues_project_issue_number")
  @@index([assignee_id], map: "ix_issues_assignee_id")
  @@index([project_id], map: "ix_issues_project_id")
  @@index([deleted_at], map: "ix_issues_deleted_at")
  @@index([due_date], map: "ix_issues_due_date")
  @@index([parent_issue_id], map: "ix_issues_parent_issue_id")
  @@index([priority], map: "ix_issues_priority")
  @@index([project_id, sprint_id, status_id], map: "ix_issues_project_sprint_status", where: raw("(deleted_at IS NULL)"))
  @@index([project_id, status_id, assignee_id], map: "ix_issues_project_status_assignee", where: raw("(deleted_at IS NULL)"))
  @@index([project_id, rank_position], map: "ix_issues_rank_position", where: raw("(deleted_at IS NULL)"))
  @@index([reporter_id], map: "ix_issues_reporter_id")
  @@index([sprint_id], map: "ix_issues_sprint_id")
  @@index([status_id], map: "ix_issues_status_id")
  @@index([type_id], map: "ix_issues_type_id")
}

